# Copy this file to .env and fill in your values.

# Groq API key — get one free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model used for AI insights (Groq-hosted). Defaults to llama-3.3-70b-versatile.
GROQ_MODEL=llama-3.3-70b-versatile

# SQLite database URL (relative path is fine for local dev)
DATABASE_URL=sqlite:///./brewiq.db

# Enable the /api/demo/* control endpoints (order simulator, rush trigger, etc.).
# Keep this true for the hackathon demo; set to false in production.
DEMO_MODE=true
